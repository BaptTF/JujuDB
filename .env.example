# JujuDB Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
POSTGRES_DB=jujudb
POSTGRES_USER=jujudb
POSTGRES_PASSWORD=your-postgres-password-here

# Application Configuration
APP_PASSWORD=your-app-password-here
SESSION_KEY=your-super-secret-session-key-32-characters-minimum

# Production Settings (set to true for production)
PRODUCTION=false
HTTPS=false

# Database Connection (for app)
DB_HOST=postgres
DB_USER=jujudb
DB_PASSWORD=your-postgres-password-here
DB_NAME=jujudb
PORT=8080
